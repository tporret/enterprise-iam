{
    "name": "enterprise/iam",
    "description": "Enterprise-grade Identity & Access Management plugin for WordPress.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "web-auth/webauthn-lib": "^5.2",
        "jumbojett/openid-connect-php": "^1.0",
        "simplesamlphp/saml2": "^6.1",
        "onelogin/php-saml": "^4.3.1"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "EnterpriseAuth\\Plugin\\": "src/php/"
        }
    },
    "scripts": {
        "lint": "docker exec wordpress sh -lc 'cd /var/www/html/wp-content/plugins/enterprise-iam && php vendor/bin/phpcs'",
        "lint:fix": "docker exec wordpress sh -lc 'cd /var/www/html/wp-content/plugins/enterprise-iam && php vendor/bin/phpcbf'"
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "simplesamlphp/composer-xmlprovider-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
